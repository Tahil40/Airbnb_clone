<% layout("/layouts/boilerplate") %>

    <body>
        <h1>All Listings</h1>
        <!-- <form action="/listings/new" method="GET">
        <button>Create New Listing</button>
    </form> -->
        <ul class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
            <% for(let listing of response_data ) { %>
                <a href="/listing/<%= listing._id %>" class="listing-link">
                    <div class="card col">
                        <img src="<%=listing.image.url%>" class="card-img-top" alt="<%=listing.image.filename%>"
                            style="height: 18rem;">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <b class="card-title">
                                <%=listing.title%>
                            </b>
                            <p class="card-text">
                                <%=listing.description%>
                            </p>
                            <p class="card-text">&#x20B9;<%=listing.price.toLocaleString("en-IN")%>/night</p>
                        </div>
                    </div>
                </a>
                <% } %>
                    <!-- <%for(let listing of response_data){%>
            <li><a href="/listing/<%= listing._id %>">
                    <%=listing.title%>
                </a></li>
            <%}%>  -->
        </ul>
    </body>