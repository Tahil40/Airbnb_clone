<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>All Listings</h1>
    <form action="/listings/new" method="GET">
        <button>Create New Listing</button>
    </form>
    <ul>
        <%for(let listing of response_data){%>
            <li><a href="/listing/<%= listing._id %>">
                    <%=listing.title%>
                </a></li>
            <%}%>
    </ul>
</body>
</html>