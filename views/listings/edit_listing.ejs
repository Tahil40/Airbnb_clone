<% layout("/layouts/boilerplate") %>

    <body>
        <form action="/edit_listing/<%=find_listing_by_id._id%>?_method=PUT" method="POST" class="needs-validation" nonvalidate>
            <div class="row mt-3">
                <div class="col-8 offset-2">
                    <h1>Edit Listing</h1>
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input name="title" value="<%=find_listing_by_id.title%>" type="text" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea name="description" class="form-control" required><%=find_listing_by_id.description%></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="image" class="form-label">Image</label>
                        <input name="image" value="<%=find_listing_by_id.image.url%>" type="text" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" value="<%=find_listing_by_id.price%>" name="price" class="form-control" required>
                    </div>
                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label for="location" class="form-label">Location</label>
                            <input type="text" value="<%=find_listing_by_id.location%>" name="location"
                                class="form-control" required>
                        </div>
                        <div class="mb-3 col-md-8">
                            <label for="country" class="form-label">Country</label>
                            <input type="text" value="<%=find_listing_by_id.country%>" name="country"
                                class="form-control" required>
                        </div>
                    </div>
                    <button class="btn btn-dark mb-3">Add</button>
                </div>
            </div>
        </form>
    </body>